# Required: API key for the CPA gateway (OpenAI-compatible). OPENAI_API_KEY also works as fallback.
LLM_CHRISTMAS_API_KEY=

# Optional: defaults to https://api.llm.christmas/v1
LLM_CHRISTMAS_BASE_URL=https://api.llm.christmas/v1

# Optional: raises GitHub API rate limits for /api/repos (unauthenticated works too)
GITHUB_TOKEN=
