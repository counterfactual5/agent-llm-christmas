# Required: OpenAI-compatible API key (llm.christmas gateway). OPENAI_API_KEY also works as fallback.
LLM_CHRISTMAS_API_KEY=

# Optional: defaults to https://api.llm.christmas/v1
LLM_CHRISTMAS_BASE_URL=https://api.llm.christmas/v1

# Optional: DeFi Agent tool-bridge base (includes /tools suffix)
TOOL_BRIDGE_BASE_URL=https://tools.defiagent.llm.christmas/tools

# Optional: raises GitHub API rate limits for /api/repos
GITHUB_TOKEN=

# Optional: improves Etherscan gas fallback rate limits
ETHERSCAN_API_KEY=
